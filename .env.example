# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
# Optional order-email delivery via Resend. Without these, notifications remain queued in Firestore.
RESEND_API_KEY=
ORDER_EMAIL_FROM=Colossal Rigout <orders@example.com>
# Optional contact-inquiry notifications via Resend.
CONTACT_EMAIL_FROM=Colossal Rigout Support <support@example.com>
CONTACT_ADMIN_EMAIL=support@example.com
